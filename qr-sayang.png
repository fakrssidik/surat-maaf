            const qrType = document.querySelector(&#39;input[name=\&#39;qr_type\&#39;]&#39;)?.value;
            if (qrType) {
                generator_link_input = qrType === &#39;Link&#39; ? (document.querySelector(&#39;input[name=\&#39;link\&#39;]&#39;)?.value || &#39;&#39;) : &#39;&#39;;
