    <div class="mt-8 lg:mt-0 mb-8" id="id_eye_style_group">
  <label class="block text-sm font-medium text-slate-900">Eye style</label>
  
  <div class="mt-2">
    <div class="flex items-center space-y-0 space-x-2">
      
      <div>
        <input id="id_eye_style_1" x-model="eye_style" name="eye_style" value="Square" type="radio" class="h-4 w-4 border-slate-300 text-blue-600 focus:ring-blue-500 hidden">
        <label for="id_eye_style_1" class="p-1 block text-sm font-medium text-slate-700 cursor-pointer border border-slate-400 rounded overflow-hidden" x-bind:class="eye_style === &#39;Square&#39; &amp;&amp; &#39;ring-2 ring-offset-1 ring-blue-600&#39;">
          
          <div class="sr-only">Square</div>
          <svg width="30" height="30" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M33.1355 3.13553H3.13553V33.1355H33.1355V3.13553Z" stroke="#222222" stroke-width="5"></path>
            <path d="M25.6355 10.6355H10.6355V25.6355H25.6355V10.6355Z" fill="#222222"></path>
          </svg>
            
            
          
        </label>
      </div>
      
      <div>
        <input id="id_eye_style_2" x-model="eye_style" name="eye_style" value="Rounded" type="radio" checked="" class="h-4 w-4 border-slate-300 text-blue-600 focus:ring-blue-500 hidden">
        <label for="id_eye_style_2" class="p-1 block text-sm font-medium text-slate-700 cursor-pointer border border-slate-400 rounded overflow-hidden ring-2 ring-offset-1 ring-blue-600" x-bind:class="eye_style === &#39;Rounded&#39; &amp;&amp; &#39;ring-2 ring-offset-1 ring-blue-600&#39;">
          
          <div class="sr-only">Round</div>
          <svg width="30" height="30" viewBox="0 0 49 49" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M37.3752 4H12C7.58172 4 4 7.58172 4 12V37.3752C4 41.7935 7.58172 45.3752 12 45.3752H37.3752C41.7935 45.3752 45.3752 41.7935 45.3752 37.3752V12C45.3752 7.58172 41.7935 4 37.3752 4Z" stroke="#222222" stroke-width="6.89586"></path>
            <path d="M31.0314 14.3438H18.3438C16.1347 14.3438 14.3438 16.1347 14.3438 18.3438V31.0314C14.3438 33.2405 16.1347 35.0314 18.3438 35.0314H31.0314C33.2405 35.0314 35.0314 33.2405 35.0314 31.0314V18.3438C35.0314 16.1347 33.2405 14.3438 31.0314 14.3438Z" fill="#222222"></path>
          </svg>
            
            
          
        </label>
      </div>
      
      <div>
        <input id="id_eye_style_3" x-model="eye_style" name="eye_style" value="Drop" type="radio" class="h-4 w-4 border-slate-300 text-blue-600 focus:ring-blue-500 hidden">
        <label for="id_eye_style_3" class="p-1 block text-sm font-medium text-slate-700 cursor-pointer border border-slate-400 rounded overflow-hidden" x-bind:class="eye_style === &#39;Drop&#39; &amp;&amp; &#39;ring-2 ring-offset-1 ring-blue-600&#39;">
          
          <div class="sr-only">Drop</div>
          <svg width="30" height="30" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.77036 2.77035H27.7704C29.0964 2.77035 30.3682 3.29713 31.3059 4.23481C32.2436 5.1725 32.7704 6.44427 32.7704 7.77035V27.7703C32.7704 29.0964 32.2436 30.3682 31.3059 31.3059C30.3682 32.2436 29.0964 32.7703 27.7704 32.7703H7.77036C6.44427 32.7703 5.1725 32.2436 4.23482 31.3059C3.29714 30.3682 2.77036 29.0964 2.77036 27.7703V2.77035Z" stroke="#222222" stroke-width="5"></path>
