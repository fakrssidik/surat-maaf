                border: false,
                submitting: false,
                expanded: true,
                secondary_color: &#39;#FFFFFF&#39;,
                eye_color_outer: &#39;#dc2626&#39;,
                frame_color: &#39;#222222&#39;,
                primary_color: &#39;#dc2626&#39;}">
